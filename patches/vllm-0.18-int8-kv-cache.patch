+# FP8-E4M3 emulation for V values in INT8 KV cache mode
+# NOTE: Evaluated at runtime (not module import) to support subprocess env vars
+def _get_fp8_v_emul() -> bool:
+    return os.getenv("VLLM_INT8_V_FP8_EMUL", "0") == "1"
+
+
+@triton.jit
+def _fp8_e4m3_decode(x_i8):
+    """Decode FP8-E4M3 format from int8 bytes to float32.
+
+    FP8-E4M3: 1 sign + 4 exponent + 3 mantissa, range [-448, 448]
+    """
+    # Convert signed int8 to unsigned interpretation
+    x_i32 = x_i8.to(tl.int32)
+    x_u8 = tl.where(x_i32 < 0, x_i32 + 256, x_i32)
+
+    # Unpack bits
+    sign = (x_u8 >> 7) & 0x1
+    exp_bits = (x_u8 >> 3) & 0xF
+    mant_bits = x_u8 & 0x7
+
+    # Decode mantissa fraction (0.0 to 0.875)
+    mant_f = mant_bits.to(tl.float32) * 0.125
+
+    # Normal: value = (1 + mant_f) * 2^(exp - 7)
+    normal = (1.0 + mant_f) * tl.exp2(exp_bits.to(tl.float32) - 7.0)
+
+    # Subnormal (exp=0): value = mant_f * 2^(-6)
+    subnormal = mant_f * tl.exp2(-6.0)
+
+    val = tl.where(exp_bits == 0, subnormal, normal)
+    return tl.where(sign == 1, -val, val)
+
 
