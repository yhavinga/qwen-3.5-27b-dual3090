+import os
 import torch
 
 from vllm.platforms import current_platform
 from vllm.triton_utils import tl, triton
 
+# FP8-E4M3 emulation for V values in INT8 KV cache mode
+# This provides better precision for V (340x variance) vs simple INT8
+# NOTE: Evaluated at runtime (not module import) to support subprocess env vars
+def _get_fp8_v_emul() -> bool:
+    return os.getenv("VLLM_INT8_V_FP8_EMUL", "0") == "1"
+
+
+@triton.jit
+def _fp8_e4m3_encode(x):
+    """Encode float32 to FP8-E4M3 format stored as int8 bytes.
+
+    FP8-E4M3: 1 sign + 4 exponent + 3 mantissa, range [-448, 448]
+    """
+    ax = tl.abs(x)
+    sign = tl.where(x < 0, 128, 0)  # sign bit = 0x80
+
+    # Handle zero
+    is_zero = ax < 1e-7
+
+    # Compute exponent and mantissa for normal numbers
+    # exp_bias = 7, so exp_bits = floor(log2(ax)) + 7
+    log_val = tl.log2(tl.maximum(ax, 1e-7))
+    exp_unbiased = tl.floor(log_val)
+    exp_unbiased = tl.maximum(tl.minimum(exp_unbiased, 7.0), -6.0)
+
+    # mantissa = (ax / 2^exp - 1) * 8, rounded
+    mant = ax / tl.exp2(exp_unbiased) - 1.0
+    mant_bits = tl.floor(mant * 8.0 + 0.5)
+
+    # Handle mantissa overflow (carry to exponent)
+    carry = mant_bits >= 8.0
+    mant_bits = tl.where(carry, 0.0, mant_bits)
+    exp_unbiased = tl.where(carry, tl.minimum(exp_unbiased + 1.0, 7.0), exp_unbiased)
+
+    exp_bits = (exp_unbiased + 7.0).to(tl.int32)  # bias = 7
+    mant_int = mant_bits.to(tl.int32)
+
+    # Subnormal: exp_bits = 0, mant encodes value directly
+    is_subnormal = ax < 0.015625  # 2^-6
+    sub_mant = tl.floor(ax * 512.0 + 0.5).to(tl.int32)  # ax * 2^9
+    sub_mant = tl.maximum(tl.minimum(sub_mant, 7), 0)
+
+    exp_bits = tl.where(is_subnormal, 0, exp_bits)
+    mant_int = tl.where(is_subnormal, sub_mant, mant_int)
+    exp_bits = tl.where(is_zero, 0, exp_bits)
+    mant_int = tl.where(is_zero, 0, mant_int)
+
+    # Pack: sign(1) | exp(4) | mant(3)
+    result = sign.to(tl.int32) | (exp_bits << 3) | mant_int
+    # Convert to signed int8 range
+    result = tl.where(result >= 128, result - 256, result)
+    return result.to(tl.int8)
+
 
